# Runtime environment variables
# Copy this file to `.env` and fill in the values you actually use.
# Environment selection: suite YAML `target_env` takes priority.
# `ENV` does NOT override YAML; it is only used when YAML omits `target_env`.

# Fallback when suite YAML does not declare `target_env`.
ENV=dev

# Shared chat defaults
CHAT_PLATFORM=tmall

# =========================
# dev
# =========================
AI_BASE_URL_DEV=https://dev.zhiyan.chat
LOGIN_ACCOUNT_DEV=
LOGIN_PASSWORD_DEV=
CHAT_ACCOUNT_DEV=测试专用1
CHAT_SHOP_ID_DEV=588
CHAT_SHOP_NAME_DEV=shop_588

# =========================
# console (production)
# =========================
AI_BASE_URL_CONSOLE=https://console.zhiyan.chat
LOGIN_ACCOUNT_CONSOLE=
LOGIN_PASSWORD_CONSOLE=
CHAT_ACCOUNT_CONSOLE=测试专用1
CHAT_SHOP_ID_CONSOLE=347
CHAT_SHOP_NAME_CONSOLE=shop_347

# Optional: when console can use a fixed bearer token, it takes precedence
# over console login/password for context and stability suites.
ACCESS_TOKEN_CONSOLE=

# Optional legacy fallback keys. Prefer the environment-specific keys above.
# LOGIN_ACCOUNT=
# LOGIN_PASSWORD=
# CHAT_ACCOUNT=

# Optional suite file overrides
# CHAT_CASES_FILE=chat_cases_wash_care_industry.yaml
# CHAT_CONTEXT_CASES_FILE=chat_context_cases.yaml
# CHAT_HIT_STABILITY_CASES_FILE=chat_hit_stability_cases.yaml
